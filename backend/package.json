    "@google-cloud/secret-manager": "^5.6.0",
    "@google-cloud/storage": "^7.12.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@sendgrid/mail": "^8.1.3",
    "axios": "^1.3.1",
    "bcryptjs": "^3.0.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^8.6.0",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "express-validator": "^6.6.1",
    "firebase": "^10.12.5",
    "firebase-admin": "^12.3.1",
    "firebase-functions": "^5.0.1",
