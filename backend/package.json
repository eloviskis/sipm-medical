{
  "name": "sipm-backend",
  "version": "1.0.0",
  "description": "Sistema Integrado de Prontuário Médico (SIPM) Backend",
  "main": "dist/app.js",
  "scripts": {
    "prebuild": "npm run prebuild-unix || npm run prebuild-win",
    "prebuild-unix": "chmod +x ./node_modules/.bin/tsc",
    "prebuild-win": "if exist .\\node_modules\\.bin\\tsc (echo Skipping chmod for Windows)",
    "start": "node dist/server.js",
    "build": "tsc",
    "test": "cross-env NODE_ENV=test npm run test:run --passWithNoTests",
    "test:run": "jest"
  },
