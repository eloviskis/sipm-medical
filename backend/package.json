    "@types/pdfkit": "^0.10.3",
    "@types/qrcode": "^1.4.1",
    "@types/speakeasy": "^2.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.9.0",
    "jest": "^29.7.0",
